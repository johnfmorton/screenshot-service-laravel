#!/usr/bin/env bash
#
# Test script for Screenshot Service installations
# Usage: ./bin/test-installation
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default values
DEFAULT_TARGET_URL="https://example.com"
POLL_INTERVAL=2
MAX_POLLS=30

print_header() {
    echo ""
    echo -e "${BLUE}========================================${NC}"
    echo -e "${BLUE}  Screenshot Service Installation Test${NC}"
    echo -e "${BLUE}========================================${NC}"
    echo ""
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_info() {
    echo -e "${YELLOW}→ $1${NC}"
}

# Check for required commands
check_dependencies() {
    if ! command -v curl &> /dev/null; then
        print_error "curl is required but not installed"
        exit 1
    fi
    if ! command -v jq &> /dev/null; then
        print_error "jq is required but not installed. Install with: brew install jq (macOS) or apt-get install jq (Linux)"
        exit 1
    fi
}

# Prompt for input with default value
prompt_with_default() {
    local prompt="$1"
    local default="$2"
    local result

    if [ -n "$default" ]; then
        read -p "$prompt [$default]: " result
        echo "${result:-$default}"
    else
        read -p "$prompt: " result
        echo "$result"
    fi
}

# Prompt for sensitive input (shows asterisks)
prompt_secret() {
    local prompt="$1"
    local result=""
    local char

    printf "%s: " "$prompt" >&2

    # Read character by character, showing asterisks
    while IFS= read -r -s -n1 char; do
        # Check for enter key (empty char)
        if [[ -z "$char" ]]; then
            break
        fi
        # Check for backspace
        if [[ "$char" == $'\x7f' ]] || [[ "$char" == $'\b' ]]; then
            if [[ -n "$result" ]]; then
                result="${result%?}"
                printf "\b \b" >&2
            fi
        else
            result+="$char"
            printf "*" >&2
        fi
    done

    echo "" >&2
    printf "%s" "$result"
}

# Test API connectivity
test_connectivity() {
    local service_url="$1"

    print_info "Testing connectivity to $service_url..."

    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 10 "$service_url" 2>/dev/null || echo "000")

    if [ "$http_code" = "000" ]; then
        print_error "Cannot connect to $service_url"
        return 1
    fi

    print_success "Connected to service (HTTP $http_code)"
    return 0
}

# Test API key validity
test_api_key() {
    local service_url="$1"
    local api_key="$2"

    print_info "Testing API key..."

    # Try to create a screenshot request to test the API key
    local response
    response=$(curl -s -X POST \
        -H "X-API-Key: $api_key" \
        -H "Content-Type: application/json" \
        -H "Accept: application/json" \
        -d '{"url":"https://example.com"}' \
        "$service_url/api/screenshots" 2>/dev/null)

    if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
        local error_msg
        error_msg=$(echo "$response" | jq -r '.message // .error')
        print_error "API key test failed: $error_msg"
        return 1
    fi

    if echo "$response" | jq -e '.id' > /dev/null 2>&1; then
        print_success "API key is valid"
        return 0
    fi

    print_error "Unexpected response: $response"
    return 1
}

# Create screenshot request
create_screenshot() {
    local service_url="$1"
    local api_key="$2"
    local target_url="$3"
    local force_refresh="$4"

    print_info "Creating screenshot request for: $target_url" >&2

    local payload
    if [ "$force_refresh" = "true" ]; then
        payload='{"url":"'"$target_url"'","force_refresh":true}'
    else
        payload='{"url":"'"$target_url"'"}'
    fi

    local response
    local http_code
    local tmp_file
    tmp_file=$(mktemp)

    local curl_error_file
    curl_error_file=$(mktemp)

    http_code=$(curl -s -w "%{http_code}" -X POST \
        -H "X-API-Key: $api_key" \
        -H "Content-Type: application/json" \
        -H "Accept: application/json" \
        -d "$payload" \
        -o "$tmp_file" \
        "$service_url/api/screenshots" 2>"$curl_error_file")

    local curl_exit_code=$?
    local curl_error
    curl_error=$(cat "$curl_error_file")
    rm -f "$curl_error_file"

    response=$(cat "$tmp_file")
    rm -f "$tmp_file"

    # Check for curl failure
    if [ "$curl_exit_code" -ne 0 ] || [ "$http_code" = "000" ]; then
        print_error "curl failed (exit code: $curl_exit_code, HTTP: $http_code)" >&2
        if [ -n "$curl_error" ]; then
            echo -e "${YELLOW}curl error:${NC} $curl_error" >&2
        fi
        echo "" >&2
        echo -e "${YELLOW}Request URL:${NC} $service_url/api/screenshots" >&2
        echo -e "${YELLOW}Payload:${NC} $payload" >&2
        echo -e "${YELLOW}API Key length:${NC} ${#api_key} characters" >&2
        echo "" >&2
        return 1
    fi

    # Check if response is valid JSON
    if ! echo "$response" | jq -e . > /dev/null 2>&1; then
        print_error "Invalid JSON response (HTTP $http_code)" >&2
        echo "" >&2
        echo -e "${YELLOW}Response body:${NC}" >&2
        echo "$response" | head -20 >&2
        echo "" >&2
        return 1
    fi

    echo "$response"
    return 0
}

# Poll for screenshot completion
poll_screenshot() {
    local service_url="$1"
    local api_key="$2"
    local screenshot_id="$3"

    local poll_count=0
    local status="pending"

    while [ "$status" = "pending" ] || [ "$status" = "processing" ]; do
        poll_count=$((poll_count + 1))

        if [ $poll_count -gt $MAX_POLLS ]; then
            print_error "Timeout waiting for screenshot (max $MAX_POLLS polls)" >&2
            echo "" >&2
            echo -e "${YELLOW}The screenshot remained in '$status' status.${NC}" >&2
            if [ "$status" = "pending" ]; then
                echo -e "${YELLOW}This usually means the queue worker is not running.${NC}" >&2
                echo -e "${YELLOW}On the server, run: php artisan queue:work --tries=3${NC}" >&2
            fi
            echo "" >&2
            return 1
        fi

        print_info "Polling status (attempt $poll_count/$MAX_POLLS)..." >&2

        local response
        response=$(curl -s \
            -H "X-API-Key: $api_key" \
            -H "Accept: application/json" \
            "$service_url/api/screenshots/$screenshot_id" 2>/dev/null)

        status=$(echo "$response" | jq -r '.status')
        print_info "Status: $status" >&2

        if [ "$status" = "completed" ]; then
            print_success "Screenshot completed" >&2
            echo "$response"
            return 0
        elif [ "$status" = "failed" ]; then
            local error_msg
            error_msg=$(echo "$response" | jq -r '.error // "Unknown error"')
            print_error "Screenshot failed: $error_msg" >&2
            return 1
        fi

        sleep $POLL_INTERVAL
    done
}

# Display results
display_results() {
    local response="$1"

    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}  Screenshot Completed Successfully${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo ""

    local full_url thumbnail_url captured_at expires_at
    full_url=$(echo "$response" | jq -r '.images.full')
    thumbnail_url=$(echo "$response" | jq -r '.images.thumbnail')
    captured_at=$(echo "$response" | jq -r '.captured_at // "N/A"')
    expires_at=$(echo "$response" | jq -r '.expires_at // "N/A"')

    echo -e "${BLUE}Full Image:${NC}"
    echo "  $full_url"
    echo ""
    echo -e "${BLUE}Thumbnail:${NC}"
    echo "  $thumbnail_url"
    echo ""
    echo -e "${BLUE}Captured At:${NC} $captured_at"
    echo -e "${BLUE}Expires At:${NC} $expires_at"
    echo ""
}

# Main function
main() {
    print_header
    check_dependencies

    # Gather inputs
    echo "Please provide the following information:"
    echo ""

    SERVICE_URL=$(prompt_with_default "Service URL (e.g., https://screenshot-service.example.com)" "")
    if [ -z "$SERVICE_URL" ]; then
        print_error "Service URL is required"
        exit 1
    fi

    # Remove trailing slash if present
    SERVICE_URL="${SERVICE_URL%/}"

    API_KEY=$(prompt_secret "API Key")
    if [ -z "$API_KEY" ]; then
        print_error "API Key is required"
        exit 1
    fi

    TARGET_URL=$(prompt_with_default "URL to screenshot" "$DEFAULT_TARGET_URL")

    read -p "Force refresh (bypass cache)? [y/N]: " force_refresh_input
    FORCE_REFRESH="false"
    if [[ "$force_refresh_input" =~ ^[Yy]$ ]]; then
        FORCE_REFRESH="true"
    fi

    echo ""
    echo -e "${BLUE}----------------------------------------${NC}"
    echo -e "${BLUE}Starting Tests${NC}"
    echo -e "${BLUE}----------------------------------------${NC}"
    echo ""

    # Test connectivity
    if ! test_connectivity "$SERVICE_URL"; then
        exit 1
    fi

    # Create screenshot
    response=$(create_screenshot "$SERVICE_URL" "$API_KEY" "$TARGET_URL" "$FORCE_REFRESH")

    if [ $? -ne 0 ]; then
        exit 1
    fi

    if echo "$response" | jq -e '.error' > /dev/null 2>&1; then
        local error_msg
        error_msg=$(echo "$response" | jq -r '.message // .error')
        print_error "Failed to create screenshot: $error_msg"
        exit 1
    fi

    local screenshot_id status
    screenshot_id=$(echo "$response" | jq -r '.id')
    status=$(echo "$response" | jq -r '.status')

    print_success "Screenshot request created (ID: $screenshot_id)"

    # If already completed (cached), display results
    if [ "$status" = "completed" ]; then
        print_success "Screenshot returned from cache"
        display_results "$response"
        exit 0
    fi

    # Poll for completion
    echo ""
    final_response=$(poll_screenshot "$SERVICE_URL" "$API_KEY" "$screenshot_id")

    if [ $? -eq 0 ]; then
        display_results "$final_response"
    else
        exit 1
    fi
}

# Run main function
main "$@"
